# Database
DATABASE_URL=postgresql+asyncpg://taskflow:taskflow@localhost:5432/taskflow
DATABASE_URL_SYNC=postgresql://taskflow:taskflow@localhost:5432/taskflow

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ASR services
ASR_URL=http://192.168.10.11:8001
ASR_DIARIZE_URL=http://192.168.10.11:8002/api/transcribe

# LLM (OpenAI-compatible API)
LLM_URL=http://192.168.10.11:8080/v1
LLM_MODEL=qwen2.5-72b-instruct
LLM_API_KEY=not-needed

# NAS storage (local path for dev; mount NAS in production)
NAS_PATH=./data/nas/meetings

MOCK_ASR=false

# SMTP (phase 5+)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# App
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
MOCK_ASR=false
